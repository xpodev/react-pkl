{
  "name": "@pkl.js/react",
  "version": "0.3.1",
  "description": "Typesafe plugin system for React",
  "author": "Xpo Development <dev@xpo.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpodev/react-pkl.git",
    "directory": "packages/core"
  },
  "homepage": "https://xpodev.github.io/react-pkl",
  "bugs": {
    "url": "https://github.com/xpodev/react-pkl/issues"
  },
  "keywords": [
    "react",
    "plugin",
    "plugin-system",
    "extensibility",
    "typescript",
    "slots",
    "layout"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
