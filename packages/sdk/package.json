{
  "name": "@pkl.js/react-sdk",
  "version": "0.3.0",
  "description": "Build tool for bundling react-pkl plugins",
  "author": "Xpo Development <dev@xpo.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpodev/react-pkl.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://xpodev.github.io/react-pkl",
  "bugs": {
    "url": "https://github.com/xpodev/react-pkl/issues"
  },
  "keywords": [
    "react",
    "plugin",
    "build-tool",
    "bundler",
    "esbuild",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "bin": {
    "pkl-build": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "esbuild": "^0.21.0"
  },
  "devDependencies": {
    "@pkl.js/react": "*",
    "@types/node": "^22.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
