{
  "name": "@react-pkl/sdk",
  "version": "0.3.0",
  "description": "Build tool for bundling react-pkl plugins",
  "type": "module",
  "bin": {
    "pkl-build": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "esbuild": "^0.21.0"
  },
  "devDependencies": {
    "@react-pkl/core": "*",
    "@types/node": "^22.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
