{
  "name": "example-plugins",
  "version": "0.1.0",
  "description": "Example plugins built with example-sdk",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hello": {
      "types": "./dist/hello-plugin.d.ts",
      "import": "./dist/hello-plugin.js",
      "require": "./dist/hello-plugin.cjs"
    },
    "./user-greeting": {
      "types": "./dist/user-greeting-plugin.d.ts",
      "import": "./dist/user-greeting-plugin.js",
      "require": "./dist/user-greeting-plugin.cjs"
    },
    "./theme-toggle": {
      "types": "./dist/theme-toggle-plugin.d.ts",
      "import": "./dist/theme-toggle-plugin.js",
      "require": "./dist/theme-toggle-plugin.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "example-sdk": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
